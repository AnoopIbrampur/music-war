# Spotify API (create an app at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# MusicBrainz requires a descriptive user agent with a contact email
MUSICBRAINZ_APP_NAME=music-war
MUSICBRAINZ_APP_VERSION=0.1.0
MUSICBRAINZ_CONTACT=you@example.com

# Database. Defaults to SQLite at data/music_war.db if unset.
# For PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/music_war
DATABASE_URL=

# Optional: path to a Kaggle Billboard Hot 100 CSV fallback
BILLBOARD_FALLBACK_CSV=
